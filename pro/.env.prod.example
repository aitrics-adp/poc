# ============================================================
# TRI-PRO POC — EC2 배포용 환경변수 (운영)
# 사용:
#   cp .env.prod.example .env
#   vim .env   # 도메인·VAPID 키 채움
#   docker compose up -d --build
# ============================================================

# ── 도메인 (Caddy가 Let's Encrypt 자동 발급) ─────────
# 도메인 있을 때:
#   PATIENT_HOST=tripro-patient.aitrics.com
# 도메인 없을 때 (nip.io — IP를 도메인처럼 사용):
#   EC2 Public IP가 13.209.10.20이면:
PATIENT_HOST=patient.13-209-10-20.nip.io
ADMIN_HOST=admin.13-209-10-20.nip.io
API_HOST=api.13-209-10-20.nip.io

# 프론트엔드 빌드 시 주입 (HTTPS 도메인)
PUBLIC_API_URL=https://api.13-209-10-20.nip.io

# CORS — 위 도메인 두 개 콤마 구분
CORS_ORIGINS=https://patient.13-209-10-20.nip.io,https://admin.13-209-10-20.nip.io

# ── DB ────────────────────────────────────────────
DB_PASSWORD=changeme_strong_password

# ── LLM ───────────────────────────────────────────
LLM_MODE=mock
ANTHROPIC_API_KEY=

# ── Web Push (VAPID) ──────────────────────────────
# 1회 생성 후 영구 보관 — 재생성하면 모든 구독 무효화
#   python3 backend/scripts/gen_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tri-pro-poc@aitrics.com

# ── 어르신 모드 ─────────────────────────────────
NEXT_PUBLIC_CAREGIVER_TEL=010-0000-0000
NEXT_PUBLIC_HOTLINE_TEL=1577-0000
